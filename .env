# ─────────────────────────────────────────────────
# YATHRA MAP — BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/yathra?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://yathra:71bAyMeL8l1A6w5O@cluster0.vjywglp.mongodb.net/?appName=Cluster0

# CORS — comma-separated list of allowed frontend origins
# Example: https://yathramap.com,https://www.yathramap.com
ALLOWED_ORIGINS=https://jsnvym.github.io/NVYM/,https://jsnvym.github.io/NVYM/

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Chat — max messages kept per room (older ones pruned)
CHAT_MESSAGE_LIMIT=200

# Max listings per collection query
LISTING_QUERY_LIMIT=30
